# ─── LLM Configuration (NVIDIA NIM) ────────────────────────────
# Lấy API key tại: https://build.nvidia.com/ → Sign in → Get API Key
OPENAI_API_KEY=nvapi-your-api-key-here
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-8b-instruct

# ─── Embedding Configuration (HuggingFace local) ──────────────
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Paths ──────────────────────────────────────────────────────
# OUTPUT_DIR=./output

# ─── Chunking ───────────────────────────────────────────────────
# CHUNK_MAX_LINES=500

# ─── API Server ─────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ─── Search ─────────────────────────────────────────────────────
# DEFAULT_TOP_K=5