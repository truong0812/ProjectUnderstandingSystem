# ─── LLM Configuration ────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─── Embedding Configuration ───────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ─── Paths ──────────────────────────────────────────────────────
# OUTPUT_DIR=./output

# ─── Chunking ───────────────────────────────────────────────────
# CHUNK_MAX_LINES=500

# ─── API Server ─────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ─── Search ─────────────────────────────────────────────────────
# DEFAULT_TOP_K=5